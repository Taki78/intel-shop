SECRET_KEY=django-insecure-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# ── آدرس عمومی سایت (برای callback پرداخت و redirect) ──────────────────────
# در dev همین باشه، در production دامنه واقعی بزن
SITE_URL=http://localhost:5173

# ── درگاه پرداخت ───────────────────────────────────────────────────────────
# Mock (پیش‌فرض dev — نیازی به API key ندارد):
PAYMENT_BACKEND=apps.payments.backends.MockPaymentBackend

# ZarinPal:
# PAYMENT_BACKEND=apps.payments.backends.ZarinPalBackend
# ZARINPAL_MERCHANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# ZARINPAL_SANDBOX=True

# IDPay:
# PAYMENT_BACKEND=apps.payments.backends.IDPayBackend
# IDPAY_API_KEY=your-idpay-api-key
# IDPAY_SANDBOX=True

# ── SMS ─────────────────────────────────────────────────────────────────────
SMS_BACKEND=apps.notifications.sms_backends.ConsoleSMSBackend
# KAVENEGAR_API_KEY=your-kavenegar-api-key

# ── Email ───────────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your@gmail.com
# EMAIL_HOST_PASSWORD=xxxx-xxxx-xxxx-xxxx
# DEFAULT_FROM_EMAIL=اینتل شاپ <your@gmail.com>
